{
  "name": "@narralang/runtime",
  "version": "0.0.1-alpha.1",
  "description": "NarraLang runtime bridge for NarraLeaf (narraleaf-react)",
  "license": "MPL-2.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ../../project/esbuild-package.mjs runtime && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json"
  },
  "peerDependencies": {
    "narraleaf-react": "^0.8.7"
  },
  "dependencies": {
    "@narralang/core": "workspace:*",
    "@narralang/share": "workspace:*"
  },
  "devDependencies": {
    "@emotion/is-prop-valid": "^1.3.1",
    "@types/node": "^20.11.18",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "motion": "^11.15.0",
    "narraleaf-react": "^0.9.0-beta.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.8.3"
  }
}
