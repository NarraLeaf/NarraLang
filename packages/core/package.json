{
  "name": "@narralang/core",
  "version": "0.0.1-alpha.1",
  "description": "NarraLang lexer, parser, and AST (language core)",
  "license": "MPL-2.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ../../project/esbuild-package.mjs core && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "test": "jest -c jest.config.cjs"
  },
  "dependencies": {
    "@narralang/share": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.18",
    "jest": "^30.0.5",
    "ts-jest": "^29.4.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
