{
  "name": "narralang-workspace",
  "private": true,
  "description": "NarraLang monorepo (core, runtime, nlc, internal share)",
  "license": "MPL-2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -Apt run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:core": "yarn workspace @narralang/core test",
    "test:nlc": "yarn workspace @narralang/nlc test",
    "test:lexer": "yarn workspace @narralang/core exec tsx test/lexer/1.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "nlc": "node ./packages/nlc/dist/cli.cjs"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.18",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "esbuild": "^0.25.6",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "jest": "^30.0.5",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "packageManager": "yarn@4.9.1"
}
